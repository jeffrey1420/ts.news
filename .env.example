# --- Real-time indexing push (scripts/notify-indexing.ts + /api/indexing/notify) ---

# Google Indexing API service account (JSON key -> client_email / private_key).
# The service account must be added as an Owner of the property in Search Console.
# https://developers.google.com/search/apis/indexing-api/v3/prereqs
GOOGLE_INDEXING_CLIENT_EMAIL="indexing@your-project.iam.gserviceaccount.com"
GOOGLE_INDEXING_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# Public site origin used to build article + feed URLs (no trailing slash).
SITE_URL="https://typescript.news"

# WebSub / PubSubHubbub hub to ping for the RSS feed.
WEBSUB_HUB_URL="https://pubsubhubbub.appspot.com/"

# Rolling publish window the script considers "fresh" (hours). --hours overrides.
INDEXING_WINDOW_HOURS="48"

# --- Server route variant (POST /api/indexing/notify) reads NUXT_-prefixed vars ---
# Same service account, surfaced through nuxt runtimeConfig:
NUXT_GOOGLE_INDEXING_CLIENT_EMAIL="indexing@your-project.iam.gserviceaccount.com"
NUXT_GOOGLE_INDEXING_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
NUXT_WEBSUB_HUB_URL="https://pubsubhubbub.appspot.com/"
# Bearer token required to call the route.
NUXT_INDEXING_PUSH_TOKEN="generate-a-long-random-secret"
